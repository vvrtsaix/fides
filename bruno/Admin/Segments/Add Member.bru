meta {
  name: Add Member
  type: http
  seq: 7
}

post {
  url: {{admin}}/admin/segments/{{segment_id}}/members
  body: json
  auth: none
}

headers {
  X-Tenant-Id: {{tenant_id}}
  content-type: application/json
}

body:json {
  {
    "external_id": "{{external_id}}"
  }
}

docs {
  Add a customer (by external_id) to the segment. Idempotent.
}
