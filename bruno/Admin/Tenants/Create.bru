meta {
  name: Create
  type: http
  seq: 1
}

post {
  url: {{admin}}/platform/tenants
  body: json
  auth: none
}

headers {
  content-type: application/json
}

body:json {
  {
    "name": "acme",
    "currency": "usd"
  }
}

script:post-response {
  if (res.body && res.body.id) bru.setEnvVar("tenant_id", res.body.id);
}

docs {
  Platform-admin, cross-tenant: no X-Tenant-Id. currency = 3-letter ISO-4217.
  Run first — populates {{tenant_id}} for every other request.
}
