meta {
  name: Create
  type: http
  seq: 1
}

post {
  url: {{admin}}/admin/tiers
  body: json
  auth: none
}

headers {
  X-Tenant-Id: {{tenant_id}}
  content-type: application/json
}

body:json {
  {
    "name": "gold",
    "threshold_points": 1000
  }
}

script:post-response {
  if (res.body && res.body.id) bru.setEnvVar("tier_id", res.body.id);
}
